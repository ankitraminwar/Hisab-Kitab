# ─── Client-side (Expo / Metro) ───────────────────────────────────────────────
# These values are read by app.config.js and exposed to the app through
# Constants.expoConfig.extra.publicEnv.
# For local dev: copy this file to .env and fill in real values.
# For EAS builds: run eas env:create with the same names (see DEPLOYMENT.md).
# These values are public in the app bundle, so never put service keys here.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Server-side ONLY (Supabase Edge Functions / Deno) ────────────────────────
# DO NOT put RESEND_API_KEY here or in EAS env vars.
# It must be set as a Supabase Edge Function secret:
#   supabase secrets set RESEND_API_KEY=your-resend-api-key
# or via Supabase Dashboard → Edge Functions → Secrets.
# RESEND_API_KEY=your-resend-api-key
